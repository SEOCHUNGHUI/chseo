# ============================================================
# Arcturus 환경 변수 예시
# cp .env.example .env 후 값을 채워주세요.
# .env 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# 패널 접속 포트
PANEL_PORT=2943

# ── PostgreSQL (Arcturus 내부용) ──────────────────────────
POSTGRES_USER=arcturus
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=arcturus

# @가 포함된 패스워드는 %40으로 URL 인코딩
DATABASE_URL=postgresql://arcturus:change_me_strong_password@postgres:5432/arcturus

# ── JWT 인증 ──────────────────────────────────────────────
# 생성: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── 관리자 계정 (최초 실행 시 자동 생성) ─────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# ── CORS ─────────────────────────────────────────────────
# 프로덕션: 실제 도메인으로 제한 예) ["https://panel.example.com"]
ALLOWED_ORIGINS=["*"]

# ── Frontend build (Vite) ─────────────────────────────────
VITE_API_BASE=
